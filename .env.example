# ============================================================
# Interview Practice App — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME=Interview Practice App
DEBUG=true
API_V1_PREFIX=/api/v1

# ── Database (local Docker PostgreSQL + pgvector) ────────────
DATABASE_URL=postgresql+asyncpg://postgres:dev_password@localhost:5432/interview_practice

# ── LLM Provider — DashScope (Claude-compatible) ─────────────
LLM_PROVIDER=dashscope
LLM_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
LLM_API_KEY=sk-sp-70c20d36702746038a01b557eb0cd471                          # ← 你自己填
LLM_MODEL_NAME=qwen3.6-plus                       # ← 填你想用的模型，如 qwen-plus
LLM_MAX_RETRIES=3
LLM_TIMEOUT=60

# ── Embedding Model (local) ─────────────────────────────────
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL_PATH=D:/AI_Project/models/bge-small-zh-v1.5
EMBEDDING_DIMENSION=512

# ── Reranker Model (local) ──────────────────────────────────
RERANKER_PROVIDER=local
RERANKER_MODEL_PATH=D:/AI_Project/models/bge-reranker-v2-m3

# ── Auth & Access Control ───────────────────────────────────
AUTH_ENABLED=false
PUBLIC_MODE=true
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── File Storage ─────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50

# ── Vector Store ─────────────────────────────────────────────
VECTOR_STORE_TYPE=pgvector
